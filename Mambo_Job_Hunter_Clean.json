    {
      "parameters": {
        "jsCode": "const aiOutput = items[0].json.output;\nconst jobData = $('Code in JavaScript1').first().json;\n\nlet parsed;\ntry {\n  const cleaned = aiOutput.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    score: 0,\n    reason: \"Could not parse AI response\",\n    suitable: false,\n    applicationType: \"Unknown\",\n    contactEmail: null\n  };\n}\n// Auto-set status based on score\nlet status = \"New\";\nif (parsed.score >= 7) {\n  status = \"Applying\";\n}\nreturn [{\n  json: {\n    jobTitle:   jobData.jobTitle,\n    company:    jobData.company,\n    location:   jobData.location,\n    experience: jobData.experience,\n    salary:     jobData.salary,\n    deadline:   jobData.deadline,\n    jobUrl:     jobData.jobUrl,\n    aiScore:    parsed.score,\n    aiReason:   parsed.reason,\n    suitable:   parsed.suitable,\n    applicationType: parsed.applicationType,\n    contactEmail:    parsed.contactEmail || '',\n    status:          status,\n    dateFound:       new Date().toISOString().split('T')[0],\n    coverLetterUrl:  '',\n    cvUrl:           '',\n    appliedDate:     '',\n    notes:           ''\n  }\n}];"
      },
