    {
      "parameters": {
        "jsCode": "const item = items[0].json;\nconst jobUrl = $node[\"Loop Over Items\"].json.jobUrl;\n\n// Clean location - remove [/jobs-location/...] parts\nconsole.log(JSON.stringify(item));\nconst cleanLocation = item.location\n  ? item.location\n      .replace(/\\[\\/jobs-location\\/[^\\]]*\\]/g, '')\n      .replace(/\\n/g, ' ')\n      .replace(/\\s+/g, ' ')\n      .trim()\n  : '';\n\n// Extract company from jobTitle\nconst titleParts = item.jobTitle\n  ? item.jobTitle.split(' at ')\n  : ['', ''];\nconst cleanTitle = titleParts[0].trim();\nconst company = titleParts.slice(1).join(' at ').trim();\n\n// Clean deadline\nconst cleanDeadline = item.deadline\n  ? item.deadline.replace('Deadline:', '').trim()\n  : '';\n\n// Clean description - remove excess newlines\nconst cleanDescription = item.description\n  ? item.description.replace(/\\n{3,}/g, '\\n\\n').trim()\n  : '';\n\nreturn [{\n  json: {\n    jobTitle: cleanTitle,\n    company: company,\n    location: cleanLocation,\n    experience: item.experience || '',\n    salary: item.salary || '',\n    deadline: cleanDeadline,\n    description: cleanDescription,\n    jobUrl: 'https://www.myjobmag.co.ke' + (jobUrl || '')\n  }\n}];"
      },
